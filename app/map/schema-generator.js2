        <div style="background: #ffffff; padding: 20px; width: 95%; max-width: 980px; box-sizing: border-box; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); font-family: Arial, sans-serif; font-size: 12px;">
